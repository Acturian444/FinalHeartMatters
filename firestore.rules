rules_version = '2';
// Firestore is not used by the website after removal of Let It Out.
// Publish these rules in the Firebase console (Firestore → Rules) so data
// is not reachable from clients. Delete unused collections in the console when ready.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
